# ===== Gemini =====
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
#GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL=gemini-2.5-flash

# ===== Report / stock =====
REPORT_TIMEZONE=Asia/Taipei
STOCK_NO=2330
HTTP_TIMEOUT_SECONDS=30

# ===== Email SMTP (Gmail) =====
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_TO=1st@ex.com,2nd@ex.com

# ===== LINE push（每日排程完成後主動推播） =====
# false = 不推播；true = 產生報告後直接推送摘要
#LINE_PUSH_ENABLED=false
LINE_PUSH_ENABLED=true
# true = 只有今天真的有新的成交資料時才推播；false = 休市日也可推播摘要
#LINE_PUSH_ONLY_IF_NEW_DATA=true
LINE_PUSH_ONLY_IF_NEW_DATA=false
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
# 目標可填 user / group / room 的 ID。常見格式：U/C/R 開頭 + 32 hex。
LINE_TO_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Optional: OpenClaw gateway token =====
OPENCLAW_GATEWAY_TOKEN=PUT_A_LONG_RANDOM_TOKEN_HERE
